<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="こんにちは、ゲストさん"
            android:textSize="20sp"
            android:textStyle="bold"
            android:paddingBottom="16dp" />

        <TextView
            android:id="@+id/sectionOsusume"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="おすすめ"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <!-- 広告枠1: placementId 1446 -->
        <io.dearone.arutanasample.BannerView
            android:id="@+id/bannerSlot1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp" />

        <TextView
            android:id="@+id/sectionPr"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PR"
            android:textSize="16sp"
            android:textStyle="bold"
            android:paddingBottom="8dp" />

        <!-- 広告枠2: placementId 99999（ダミー / 配信なしなら消し込み） -->
        <io.dearone.arutanasample.BannerView
            android:id="@+id/bannerSlot2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
